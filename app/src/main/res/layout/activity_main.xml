<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top: Logo area (hidden when image loaded) -->
        <LinearLayout
            android:id="@+id/logoArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="200dp"
                android:layout_height="66dp"
                android:src="@drawable/watermark_logo"
                android:scaleType="fitCenter"
                android:contentDescription="Logo" />

            <TextView
                android:id="@+id/tvLogoSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Moto Watermark"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Center hint (hidden when image loaded) -->
        <TextView
            android:id="@+id/tvCenterHint"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tap + to add watermark\nLong press + for batch mode"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:visibility="visible" />

        <!-- Image Preview in MaterialCardView (shown when image loaded) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/md_theme_surfaceVariant"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />
        </com.google.android.material.card.MaterialCardView>

        <!-- FABs - between preview and control panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:layout_marginEnd="16dp">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Camera"
                app:fabSize="mini"
                app:tint="@color/md_theme_onPrimary"
                app:backgroundTint="@color/md_theme_primary" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_input_add"
                android:contentDescription="@string/select_photo"
                app:fabSize="mini"
                app:tint="@color/md_theme_onPrimary"
                app:backgroundTint="@color/md_theme_primary" />


            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabRotate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:contentDescription="Rotate"
                android:visibility="gone"
                app:fabSize="mini"
                app:tint="@color/md_theme_onSecondary"
                app:backgroundTint="@color/md_theme_secondary" />


            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_menu_save"
                android:contentDescription="@string/save_image"
                android:visibility="gone"
                app:fabSize="mini"
                app:tint="@color/md_theme_onTertiary"
                app:backgroundTint="@color/md_theme_tertiary" />
        </LinearLayout>

        <!-- Bottom Control Panel -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/md_theme_surface"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <!-- Section: Style -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STYLE"
                    android:textSize="11sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/styleChipGroup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:singleSelection="true"
                        app:chipSpacingHorizontal="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle1"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Standard"
                            android:textSize="13sp"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle2"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Blur"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle3"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Corner"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle4"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Classic"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle5"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Film"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle6"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Label"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle7"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Strip"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle8"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Badge"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle9"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Cinema"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle10"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Transp."
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStyle11"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="F1"
                            android:textSize="13sp" />
                    </com.google.android.material.chip.ChipGroup>

                    <ImageView
                        android:id="@+id/ivStylePreview"
                        android:layout_width="48dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Style preview" />
                </LinearLayout>

                <!-- Pick color chip (added dynamically) -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/colorChipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:chipSpacingHorizontal="6dp"
                    android:layout_marginTop="10dp" />

                <!-- Section: Owner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="Owner"
                        android:textSize="13sp"
                        android:textColor="@color/md_theme_onSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                        app:hintTextColor="@color/md_theme_onSurfaceVariant"
                        app:boxStrokeColor="@color/md_theme_outline">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etOwnerName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@stephen"
                            android:maxLines="1"
                            android:textSize="14sp"
                            android:inputType="textPersonName|textNoSuggestions"
                            android:textColor="@color/md_theme_onSurface" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/md_theme_outlineVariant"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="6dp" />

                <!-- Section: Toggles - clean 2-column grid -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOGGLES"
                    android:textSize="11sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />

                <!-- Row: Params | Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchParams"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Params"
                        android:textSize="13sp"
                        android:textColor="@color/md_theme_onSurface"
                        android:checked="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDate"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Date"
                        android:textSize="13sp"
                        android:textColor="@color/md_theme_onSurface"
                        android:checked="true" />
                </LinearLayout>

                <!-- Row: Logo | PNG -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchLogo"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Logo"
                        android:textSize="13sp"
                        android:textColor="@color/md_theme_onSurface"
                        android:checked="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchPng"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="PNG"
                        android:textSize="13sp"
                        android:textColor="@color/md_theme_onSurface"
                        android:checked="true" />
                </LinearLayout>

                <!-- Row: White Text | White BG -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchWhiteText"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="White Text"
                        android:textSize="13sp"
                        android:textColor="@color/md_theme_onSurface"
                        android:checked="false" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchWhiteBg"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="White BG"
                        android:textSize="13sp"
                        android:textColor="@color/md_theme_onSurface"
                        android:checked="false" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Status overlay -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/md_theme_onSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
